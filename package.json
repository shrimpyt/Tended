{
  "name": "tended-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=tended-web",
    "build:web": "npm run build --workspace=tended-web",
    "start:web": "npm run start --workspace=tended-web",
    "lint:web": "npm run lint --workspace=tended-web",
    "dev:mobile": "npm run start --workspace=tended",
    "android": "npm run android --workspace=tended",
    "ios": "npm run ios --workspace=tended"
  }
}
